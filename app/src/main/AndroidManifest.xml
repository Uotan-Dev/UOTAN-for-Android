<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 权限配置 -->
    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 读写权限 (SDK ≤ 32) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"
        tools:ignore="ScopedStorage" />
    <!-- 读写权限 (Google Play 禁用) -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="AllFilesAccessPolicy,ScopedStorage" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"
        tools:ignore="PhotoAndVideoPolicy" />
    <!-- 读写权限 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />
    <!-- 安装权限 (Google Play 禁用) -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"
        tools:ignore="RequestInstallPackagesPolicy" />
    <!-- 震动权限 -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- 通知权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />

    <application
        android:name=".UotanApplication"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Base.Theme.Uotan">

        <!-- MIUI/HyperOS 卸载挽留 -->
        <meta-data
            android:name="app_description_title"
            android:resource="@string/uninstall_title"/>
        <meta-data
            android:name="app_description_content"
            android:resource="@string/uotan_describe" />

        <activity
            android:name=".welcome.ui.WelcomeActivity"
            android:exported="false" />
        <activity
            android:name=".settings.ui.profile.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".section.ui.CategoriesActivity"
            android:exported="false" />
        <activity
            android:name=".settings.ui.DomainActivity"
            android:exported="false" />
        <activity
            android:name=".threads.ui.ThreadsActivity"
            android:exported="false" />
        <activity
            android:name=".user.ui.UserActivity"
            android:exported="false" />
        <activity
            android:name=".startup.ui.StartupActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- 桌面 Shortcuts -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />

        </activity>
        <activity
            android:name=".main.ui.MainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".settings.ui.SettingsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.UpdatePolicyActivity"
            android:exported="false" />
        <activity
            android:name=".settings.ui.about.AboutActivity"
            android:exported="false" />
        <activity
            android:name=".resource.ui.details.ResourceActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.FindUpdateActivity"
            android:exported="false" />
        <activity
            android:name=".section.ui.SectionDataActivity"
            android:exported="false" />
        <activity
            android:name=".search.ui.SearchResultActivity"
            android:exported="false" />
        <activity
            android:name=".search.ui.SearchActivity"
            android:exported="false" />
        <activity
            android:name=".AgreementPolicyActivity"
            android:exported="false" />
        <activity
            android:name=".settings.ui.PolicyActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.UpdaterActivity"
            android:exported="false" />
        <activity
            android:name=".settings.ui.ThemeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.SelectSectionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.PostArticleActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.BindPhoneActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activity.PlaceholderActivity"
            android:exported="false" />

        <property
            android:name="android.window.PROPERTY_ACTIVITY_EMBEDDING_SPLITS_ENABLED"
            android:value="true" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.gustate.uotan.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="com.gustate.uotan.ui.activity.SplitInitializer"
                android:value="androidx.startup" />
        </provider>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>