<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Window Background -->
    <attr name="colorBackground" format="color" />
    <!-- On Window Background Primary -->
    <attr name="colorOnBackgroundPrimary" format="color" />
    <!-- On Window Background Secondary -->
    <attr name="colorOnBackgroundSecondary" format="color" />
    <!-- On Window Background Tertiary -->
    <attr name="colorOnBackgroundTertiary" format="color" />

    <!-- Filled Button Normal -->
    <attr name="colorFilledButtonNormal" format="color" />
    <!-- Filled Button Press -->
    <attr name="colorFilledButtonPress" format="color" />
    <!-- On Filled Button -->
    <attr name="colorOnFilledButton" format="color" />

    <!-- Filled Tonal Button Normal -->
    <attr name="colorFilledTonalButtonNormal" format="color" />
    <!-- Filled Tonal Button Press -->
    <attr name="colorFilledTonalButtonPress" format="color" />
    <!-- On Filled Tonal Button -->
    <attr name="colorOnFilledTonalButton" format="color" />

    <!-- Card Normal -->
    <attr name="colorCardNormal" format="color" />
    <!-- Card Press -->
    <attr name="colorCardPress" format="color" />
    <!-- On Card Primary -->
    <attr name="colorOnCardPrimary" format="color"/>
    <!-- On Card Secondary -->
    <attr name="colorOnCardSecondary" format="color"/>

    <!-- Error Card -->
    <attr name="colorErrorCard" format="color"/>
    <!-- On Error Card -->
    <attr name="colorOnErrorCard" format="color"/>

    <!-- Switch Unchecked Track -->
    <attr name="colorSwitchTrackUnchecked" format="color" />
    <!-- Switch Checked Track -->
    <attr name="colorSwitchTrackChecked" format="color" />
    <!-- Switch Unchecked Thumb -->
    <attr name="colorSwitchThumbUnchecked" format="color" />
    <!-- Switch Checked Thumb -->
    <attr name="colorSwitchThumbChecked" format="color" />

    <!-- Dialog Background -->
    <attr name="colorDialogBackground" format="color" />
    <!-- On Dialog Normal -->
    <attr name="colorOnDialogNormal" format="color" />
    <!-- On Dialog Press -->
    <attr name="colorOnDialogPress" format="color" />
    <!-- Dialog Tap -->
    <attr name="colorDialogTap" format="color" />

    <!-- Bottom Navigation Bar Background (Blur Cover) -->
    <attr name="colorBottomNavigationBarBackground" format="color" />
    <!-- Bottom Navigation Bar On Background Primary -->
    <attr name="colorBottomNavigationBarOnBackgroundPrimary" format="color" />
    <!-- Bottom Navigation Bar On Background Secondary -->
    <attr name="colorBottomNavigationBarOnBackgroundSecondary" format="color" />

    <!-- Floating Button Background Normal -->
    <attr name="colorFloatingButtonBackgroundNormal" format="color" />
    <!-- Floating Button Background Press -->
    <attr name="colorFloatingButtonBackgroundPress" format="color" />

    <declare-styleable name="OptionView">
        <attr name="optionIcon" format="reference" />
        <attr name="optionTitle" format="string" />
    </declare-styleable>

    <declare-styleable name="OptionOnlyTitleView">
        <attr name="optionTitle_onlyTitle" format="string" />
    </declare-styleable>

    <declare-styleable name="OptionDetailView">
        <attr name="android:background" format="reference" />
        <attr name="odv_title" format="string" />
        <attr name="odv_detail" format="string" />
        <attr name="odv_arrow_gone" format="boolean" />
    </declare-styleable>

    <declare-styleable name="OptionTitleAndDescribeView">
        <attr name="optionTitle_tiltleAndDescribe" format="string" />
        <attr name="optionDescribe_tiltleAndDescribe" format="string" />
    </declare-styleable>

    <declare-styleable name="OptionUserView">
        <attr name="ouv_avatar_assets" format="string" />
        <attr name="ouv_title" format="string" />
        <attr name="ouv_describe" format="string" />
    </declare-styleable>

    <declare-styleable name="SmoothCornerLayout">
        <attr name="scl_corner_radius" format="dimension" />
        <attr name="scl_smoothness_radius" format="float" />

        <attr name="scl_corner_radius_tl" format="dimension" />
        <attr name="scl_smoothness_radius_tl" format="float" />
        <attr name="scl_corner_radius_tr" format="dimension" />
        <attr name="scl_smoothness_radius_tr" format="float" />
        <attr name="scl_corner_radius_br" format="dimension" />
        <attr name="scl_smoothness_radius_br" format="float" />
        <attr name="scl_corner_radius_bl" format="dimension" />
        <attr name="scl_smoothness_radius_bl" format="float" />
        <!-- 边框 -->
        <attr name="scl_border_width" format="dimension"/>
        <attr name="scl_border_color" format="color"/>
        <!-- 是否裁剪子视图 -->
        <attr name="clipChildren" format="boolean" />

        <attr name="scl_shadow_color" format="color" />
        <attr name="scl_shadow_radius" format="dimension" />
        <attr name="scl_shadow_x" format="dimension" />
        <attr name="scl_shadow_y" format="dimension" />
    </declare-styleable>

</resources>
