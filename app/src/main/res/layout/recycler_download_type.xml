<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.uotan.forum.ui.view.smooth.SmoothCornerLayout
        android:id="@+id/itemLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/gustatex_on_dialog_background_normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:scl_corner_radius="@dimen/option_corner_radius"
        app:scl_smoothness_radius="@dimen/normal_smoothness">

        <TextView
            android:id="@+id/tvDrive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="18dp"
            android:textColor="?attr/colorOnCardPrimary"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.uotan.forum.ui.view.smooth.SmoothCornerLayout
            android:id="@+id/btn_download"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvDrive"
            app:scl_corner_radius="@dimen/normal_corner_radius"
            app:scl_smoothness_radius="@dimen/normal_smoothness">

            <TextView
                android:id="@+id/tv_download"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:background="@drawable/uotan_btn_filled"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="@string/download"
                android:textColor="?attr/colorOnFilledButton"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </com.uotan.forum.ui.view.smooth.SmoothCornerLayout>
    </com.uotan.forum.ui.view.smooth.SmoothCornerLayout>
</androidx.constraintlayout.widget.ConstraintLayout>